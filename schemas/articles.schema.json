{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/indanya/articles.schema.json",
  "title": "淫談屋 article metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "title",
    "category",
    "status",
    "published_at",
    "display_date",
    "comments",
    "url",
    "thumbnail",
    "source_url",
    "images_used"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 100
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "status": {
      "enum": [
        "draft",
        "published",
        "archived"
      ]
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "display_date": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}$"
    },
    "comments": {
      "type": "integer",
      "minimum": 0
    },
    "url": {
      "type": "string",
      "pattern": "^articles/[a-z0-9-]+\\.html$"
    },
    "thumbnail": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "images_used": {
      "type": "integer",
      "minimum": 1
    },
    "summary": {
      "type": "string",
      "maxLength": 240
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 40
      },
      "uniqueItems": true
    },
    "featured": {
      "type": "boolean"
    }
  }
}