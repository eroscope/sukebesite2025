{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "summary", "category", "tags", "responses"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "category": {
      "type": "string",
      "enum": ["SNS", "画像", "動画", "話題"]
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 40
      }
    },
    "responses": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "style", "video_ids"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "style": {
            "type": "string",
            "enum": ["normal", "large", "highlight"]
          },
          "video_ids": {
            "type": "array",
            "maxItems": 2,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            }
          }
        }
      }
    }
  }
}
