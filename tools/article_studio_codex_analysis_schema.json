{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "description", "category", "page_role", "follow_url", "follow_reason", "analysis_summary", "fanza_relevance", "fanza_performer_name", "fanza_search_query", "fanza_product_code", "fanza_reason", "fanza_people", "image_decisions", "video_decisions"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "category": {
      "type": "string",
      "enum": ["SNS", "画像", "動画", "話題"]
    },
    "page_role": {
      "type": "string",
      "enum": ["article", "gateway", "index", "unclear"]
    },
    "follow_url": {
      "type": "string",
      "maxLength": 2048
    },
    "follow_reason": {
      "type": "string",
      "maxLength": 300
    },
    "analysis_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "fanza_relevance": {
      "type": "string",
      "enum": ["none", "related", "likely_product", "exact_product"]
    },
    "fanza_performer_name": {
      "type": "string",
      "maxLength": 80
    },
    "fanza_search_query": {
      "type": "string",
      "maxLength": 120
    },
    "fanza_product_code": {
      "type": "string",
      "maxLength": 40
    },
    "fanza_reason": {
      "type": "string",
      "maxLength": 240
    },
    "fanza_people": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "image_ids", "reason"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "image_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 40
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    },
    "image_decisions": {
      "type": "array",
      "maxItems": 120,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["image_id", "verdict", "role", "recommended_use", "content_group", "relation", "relevance_score", "reason"],
        "properties": {
          "image_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "verdict": {
            "type": "string",
            "enum": ["article", "advertisement", "logo", "navigation", "unrelated", "unclear"]
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "recommended_use": {
            "type": "string",
            "enum": ["thumbnail", "body", "thumbnail_and_body", "exclude"]
          },
          "content_group": {
            "type": "string",
            "maxLength": 80
          },
          "relation": {
            "type": "string",
            "maxLength": 160
          },
          "relevance_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          }
        }
      }
    },
    "video_decisions": {
      "type": "array",
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["video_id", "verdict", "relevance_score", "reason"],
        "properties": {
          "video_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "verdict": {
            "type": "string",
            "enum": ["article", "advertisement", "navigation", "unrelated", "unclear"]
          },
          "relevance_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          }
        }
      }
    }
  }
}
